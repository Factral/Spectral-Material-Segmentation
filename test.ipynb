    "import torch\n",
    "import matplotlib.pyplot as plt\n",
    "# generate a tensor of size 256x256x31 with numbers between -2 and 2\n",
    "x = torch.rand(256, 256, 31) * 4 - 2\n",
    "\n",
    "plt.plot(x[0, 0, :])\n",
    "\n",
    "x.min(), x.max()"
